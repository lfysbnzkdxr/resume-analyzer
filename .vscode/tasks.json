{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Streamlit Run",
            "type": "shell",
            "command": "${workspaceFolder}/venv/Scripts/streamlit.exe",
            "args": [
                "run",
                "${workspaceFolder}/src/main.py"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        }
    ]
}
